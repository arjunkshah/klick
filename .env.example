# Copy to `.env.local` for local dev (do not commit `.env.local`).

# Gemini (Dex) — server only, not VITE_*.
# Vercel: add `geminikey` in Project → Settings → Environment Variables.
# Local: same name in `.env.local` (see server/index.js dotenv loader).
geminikey=
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# If the Dex API lives on another origin (rare). Empty = same-origin (Vercel / dev proxy).
# VITE_DEX_API_ORIGIN=https://your-deployment.vercel.app

# If port 8787 is already in use (EADDRINUSE), pick another port and matching proxy:
# DEX_API_PORT=8788
# DEX_API_PROXY=http://127.0.0.1:8788

# Firebase Web SDK → use these exact names in Vercel: Settings → Environment Variables.
# Console: Project settings → Your apps → SDK setup (or General → Your apps).
# Also enable Authentication → Sign-in method (Google + Email/Password).
# Deploy Firestore rules from this repo (`firebase.json` → `firestore.rules`).
#
# firebaseConfig field → Vercel / env name
#   apiKey            → VITE_FIREBASE_API_KEY
#   authDomain        → VITE_FIREBASE_AUTH_DOMAIN
#   projectId         → VITE_FIREBASE_PROJECT_ID
#   storageBucket     → VITE_FIREBASE_STORAGE_BUCKET
#   messagingSenderId → VITE_FIREBASE_MESSAGING_SENDER_ID
#   appId             → VITE_FIREBASE_APP_ID
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# —— Integrations (Vercel / serverless OAuth) ——
# JSON string of Firebase service account (Project settings → Service accounts → Generate key).
# Required for Slack & GitHub OAuth callbacks to write Firestore.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Random secret (min 16 chars) to sign OAuth state tokens.
INTEGRATION_OAUTH_SECRET=
# Public site URL for redirects (optional if VERCEL_URL is set).
APP_ORIGIN=
# Slack app: api.slack.com/apps → OAuth & Permissions
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# GitHub OAuth app: github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
